---
interface FormLabels {
  nameLabel: string;
  emailLabel: string;
  messageLabel: string;
  submitLabel: string;
}

interface Props {
  formLabels: FormLabels;
  locale: "fr" | "en";
  recipientEmail?: string;
  triggerLabel?: string;
  showTrigger?: boolean;
  modalId?: string;
}

const {
  formLabels,
  locale,
  recipientEmail = "hello@exitmediagroup.com",
  triggerLabel,
  showTrigger = true,
  modalId = "footer-form",
} = Astro.props;
const resolvedTriggerLabel =
  triggerLabel ?? (locale === "fr" ? "Nous contacter" : "Contact us");
---

<div class="contact-form">
  {showTrigger && (
    <button
      type="button"
      class="contact-form__open"
      data-contact-modal-open-target={modalId}
    >
      {resolvedTriggerLabel}
    </button>
  )}

  <dialog
    id={modalId}
    class="contact-form__modal"
    data-contact-modal
    data-contact-modal-id={modalId}
    aria-label={locale === "fr" ? "Formulaire de contact" : "Contact form"}
  >
    <div class="contact-form__modal-head">
      <h3>{locale === "fr" ? "Parlons de votre projet" : "Let's talk about your project"}</h3>
      <button
        type="button"
        class="contact-form__close"
        data-contact-modal-close
        aria-label={locale === "fr" ? "Fermer" : "Close"}
      >
        ×
      </button>
    </div>
    <p class="contact-form__success" role="status" data-contact-success hidden>
      {locale === "fr"
        ? "Votre message est pret. Finalisez l'envoi dans votre application email."
        : "Your message is ready. Finish sending it from your email app."}
    </p>
    <p class="contact-form__error" role="alert" data-contact-error hidden>
      {locale === "fr"
        ? "Impossible d'ouvrir votre application email. Merci d'ecrire a l'adresse ci-dessous."
        : "Could not open your email app. Please write to the address below."}
    </p>
    <form
      method="dialog"
      class="contact-form__form"
      data-contact-form-id={modalId}
      data-contact-recipient={recipientEmail}
      aria-label={locale === "fr" ? "Formulaire de contact" : "Contact form"}
    >
      <input type="hidden" name="locale" value={locale} />
      <div class="contact-form__field">
        <label for={`${modalId}-name`}>{formLabels.nameLabel}</label>
        <input
          id={`${modalId}-name`}
          type="text"
          name="name"
          required
          autocomplete="name"
          class="contact-form__input"
        />
      </div>
      <div class="contact-form__field">
        <label for={`${modalId}-email`}>{formLabels.emailLabel}</label>
        <input
          id={`${modalId}-email`}
          type="email"
          name="email"
          required
          autocomplete="email"
          class="contact-form__input"
        />
      </div>
      <div class="contact-form__field">
        <label for={`${modalId}-message`}>{formLabels.messageLabel}</label>
        <textarea
          id={`${modalId}-message`}
          name="message"
          required
          rows={4}
          class="contact-form__input contact-form__textarea"
        />
      </div>
      <button type="submit" class="contact-form__submit">
        {formLabels.submitLabel}
      </button>
    </form>
  </dialog>
</div>

<script>
  const setupContactModal = () => {
    const messages = {
      fr: {
        subject: "Nouveau message depuis exitMediaGroup",
      },
      en: {
        subject: "New message from exitMediaGroup",
      },
    } as const;

    const getDraftKey = (id: string) => `contact-form-draft:${id}`;
    const readDraft = (id: string): Partial<Record<"name" | "email" | "message", string>> => {
      try {
        const raw = window.sessionStorage.getItem(getDraftKey(id));
        if (!raw) return {};
        const parsed = JSON.parse(raw) as Partial<Record<"name" | "email" | "message", string>>;
        return parsed ?? {};
      } catch {
        return {};
      }
    };

    const writeDraft = (id: string, payload: Partial<Record<"name" | "email" | "message", string>>) => {
      try {
        window.sessionStorage.setItem(getDraftKey(id), JSON.stringify(payload));
      } catch {
        // Ignore storage failures so submit flow is never blocked.
      }
    };

    const clearDraft = (id: string) => {
      try {
        window.sessionStorage.removeItem(getDraftKey(id));
      } catch {
        // Ignore storage failures.
      }
    };

    document.querySelectorAll<HTMLFormElement>("[data-contact-form-id]").forEach((form) => {
      const id = form.getAttribute("data-contact-form-id");
      if (!id || form.dataset.formBound === "true") return;
      form.dataset.formBound = "true";

      const nameInput = form.querySelector<HTMLInputElement>('input[name="name"]');
      const emailInput = form.querySelector<HTMLInputElement>('input[name="email"]');
      const messageInput = form.querySelector<HTMLTextAreaElement>('textarea[name="message"]');
      const localeInput = form.querySelector<HTMLInputElement>('input[name="locale"]');
      const successEl = form.parentElement?.querySelector<HTMLElement>("[data-contact-success]");
      const errorEl = form.parentElement?.querySelector<HTMLElement>("[data-contact-error]");
      const recipient = form.getAttribute("data-contact-recipient") ?? "";

      const draft = readDraft(id);
      if (nameInput && draft.name) nameInput.value = draft.name;
      if (emailInput && draft.email) emailInput.value = draft.email;
      if (messageInput && draft.message) messageInput.value = draft.message;

      form.addEventListener("submit", (event) => {
        event.preventDefault();

        successEl?.setAttribute("hidden", "");
        errorEl?.setAttribute("hidden", "");

        if (!recipient || !nameInput || !emailInput || !messageInput || !localeInput) {
          errorEl?.removeAttribute("hidden");
          return;
        }

        if (!form.reportValidity()) return;

        writeDraft(id, {
          name: nameInput?.value ?? "",
          email: emailInput?.value ?? "",
          message: messageInput?.value ?? "",
        });

        const locale = localeInput.value === "en" ? "en" : "fr";
        const subject = messages[locale].subject;
        const body = [
          locale === "fr" ? "Nom" : "Name",
          `: ${nameInput.value}`,
          "\n",
          locale === "fr" ? "Email" : "Email",
          `: ${emailInput.value}`,
          "\n\n",
          locale === "fr" ? "Message" : "Message",
          ":\n",
          messageInput.value,
        ].join("");

        const mailtoHref = `mailto:${recipient}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;

        try {
          window.location.href = mailtoHref;
          clearDraft(id);
          form.reset();
          successEl?.removeAttribute("hidden");
        } catch {
          errorEl?.removeAttribute("hidden");
        }
      });
    });

    const modals = document.querySelectorAll("[data-contact-modal]");

    modals.forEach((node) => {
      if (!(node instanceof HTMLDialogElement)) return;
      if (node.dataset.modalBound === "true") return;
      const id = node.getAttribute("data-contact-modal-id");
      if (!id) return;
      node.dataset.modalBound = "true";

      const openModal = () => {
        if (typeof node.showModal === "function" && !node.open) {
          node.showModal();
        }
      };

      const closeModal = () => {
        if (node.open) node.close();
      };

      document
        .querySelectorAll(`[data-contact-modal-open-target="${id}"]`)
        .forEach((trigger) => {
          if (!(trigger instanceof HTMLElement)) return;
          trigger.addEventListener("click", (event) => {
            event.preventDefault();
            openModal();
          });
        });

      node.addEventListener("click", (event) => {
        if (event.target === node) closeModal();
      });

      node.querySelectorAll("[data-contact-modal-close]").forEach((closeTrigger) => {
        closeTrigger.addEventListener("click", () => closeModal());
      });

      if (window.location.hash === `#${id}`) {
        openModal();
      }
    });
  };

  document.addEventListener("astro:page-load", setupContactModal);
</script>

<style>
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .contact-form__open {
    align-self: flex-start;
    margin-top: var(--space-xs);
    padding: var(--space-md) var(--space-2xl);
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: var(--radius-md);
    color: var(--color-text-primary);
    font-family: var(--font-family-display);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    transition:
      border-color var(--motion-duration-fast) var(--motion-ease-standard),
      color var(--motion-duration-fast) var(--motion-ease-standard),
      background var(--motion-duration-fast) var(--motion-ease-standard),
      transform var(--motion-duration-fast) var(--motion-ease-standard);
  }

  .contact-form__open:hover {
    border-color: rgba(255, 255, 255, 0.5);
    background: rgba(255, 255, 255, 0.1);
    color: white;
    transform: translateY(-1px);
  }

  .contact-form__modal {
    position: fixed;
    inset: 0;
    margin: auto;
    width: min(100%, 34rem);
    max-height: min(90svh, 46rem);
    overflow: auto;
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: var(--radius-lg);
    background: color-mix(in srgb, var(--color-bg-canvas) 90%, transparent);
    color: var(--color-text-primary);
    padding: clamp(1rem, 2.8vw, 1.5rem);
    box-shadow: 0 20px 50px rgba(2, 4, 14, 0.55);
  }

  .contact-form__modal::backdrop {
    background: rgba(5, 8, 22, 0.7);
    backdrop-filter: blur(4px);
  }

  .contact-form__modal-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.8rem;
  }

  .contact-form__modal-head h3 {
    margin: 0;
    font-family: var(--font-family-display);
    font-size: 1.05rem;
  }

  .contact-form__close {
    border: 0;
    background: transparent;
    color: var(--color-text-secondary);
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
    padding: 0;
  }

  .contact-form__close:hover {
    color: var(--color-text-primary);
  }

  .contact-form__success {
    padding: var(--space-md) var(--space-lg);
    margin-bottom: var(--space-lg);
    background: rgba(34, 197, 94, 0.12);
    border: 1px solid rgba(34, 197, 94, 0.35);
    border-radius: var(--radius-md);
    color: #86efac;
    font-size: 0.9375rem;
    line-height: 1.5;
  }

  .contact-form__error {
    padding: var(--space-md) var(--space-lg);
    margin-bottom: var(--space-lg);
    background: rgba(239, 68, 68, 0.12);
    border: 1px solid rgba(239, 68, 68, 0.35);
    border-radius: var(--radius-md);
    color: #fca5a5;
    font-size: 0.9375rem;
    line-height: 1.5;
  }

  .contact-form__form {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .contact-form__field {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .contact-form__field label {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    letter-spacing: 0.02em;
  }

  .contact-form__input {
    width: 100%;
    padding: var(--space-md) var(--space-lg);
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: var(--radius-md);
    color: var(--color-text-primary);
    font-family: inherit;
    font-size: 1rem;
    line-height: 1.5;
    transition:
      border-color var(--motion-duration-fast) var(--motion-ease-standard),
      background var(--motion-duration-fast) var(--motion-ease-standard),
      box-shadow var(--motion-duration-fast) var(--motion-ease-standard);
  }

  .contact-form__input::placeholder {
    color: var(--color-text-muted);
  }

  .contact-form__input:hover {
    border-color: rgba(255, 255, 255, 0.28);
    background: rgba(255, 255, 255, 0.05);
  }

  .contact-form__input:focus {
    border-color: rgba(127, 114, 255, 0.6);
    background: rgba(255, 255, 255, 0.05);
    box-shadow: 0 0 0 3px rgba(127, 114, 255, 0.15);
    outline: none;
  }

  .contact-form__textarea {
    resize: vertical;
    min-height: 6.5rem;
    padding-top: var(--space-md);
  }

  .contact-form__submit {
    align-self: flex-start;
    margin-top: var(--space-xs);
    padding: var(--space-md) var(--space-2xl);
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: var(--radius-md);
    color: var(--color-text-primary);
    font-family: var(--font-family-display);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    transition:
      border-color var(--motion-duration-fast) var(--motion-ease-standard),
      color var(--motion-duration-fast) var(--motion-ease-standard),
      background var(--motion-duration-fast) var(--motion-ease-standard),
      transform var(--motion-duration-fast) var(--motion-ease-standard);
  }

  .contact-form__submit:hover {
    border-color: rgba(255, 255, 255, 0.5);
    background: rgba(255, 255, 255, 0.1);
    color: white;
    transform: translateY(-1px);
  }

  .contact-form__submit:focus-visible {
    outline: 2px solid rgba(127, 114, 255, 0.6);
    outline-offset: 2px;
  }

  .contact-form__submit:active {
    transform: translateY(0);
  }

  @media (max-width: 48rem) {
    .contact-form__modal {
      width: min(100%, 92vw);
      padding: 1rem;
    }
  }
</style>
