---
import { actions } from "astro:actions";
import { isInputError } from "astro:actions";

interface FormLabels {
  nameLabel: string;
  emailLabel: string;
  messageLabel: string;
  submitLabel: string;
}

interface Props {
  formLabels: FormLabels;
  locale: "fr" | "en";
  result?: Awaited<ReturnType<typeof actions.sendContact>>;
}

const { formLabels, locale, result } = Astro.props;
const hasError = result?.error;
const hasSuccess = result?.data?.success;
const inputErrors = isInputError(hasError) ? hasError.fields : {};
---

<div class="contact-form" id="footer-form">
  {hasSuccess && (
    <p class="contact-form__success" role="status">
      {locale === "fr"
        ? "Votre message a bien été envoyé. Nous vous répondrons rapidement."
        : "Your message has been sent. We will get back to you soon."}
    </p>
  )}
  {hasError && !isInputError(hasError) && (
    <p class="contact-form__error" role="alert">
      {hasError.message}
    </p>
  )}
  <form
    method="POST"
    action={actions.sendContact}
    class="contact-form__form"
    aria-label={locale === "fr" ? "Formulaire de contact" : "Contact form"}
  >
    <input type="hidden" name="locale" value={locale} />
    <div class="contact-form__field">
      <label for="contact-name">{formLabels.nameLabel}</label>
      <input
        id="contact-name"
        type="text"
        name="name"
        required
        autocomplete="name"
        class="contact-form__input"
        aria-describedby={inputErrors.name ? "contact-name-error" : undefined}
        aria-invalid={!!inputErrors.name}
      />
      {inputErrors?.name && (
        <span id="contact-name-error" class="contact-form__field-error">
          {inputErrors.name.join(", ")}
        </span>
      )}
    </div>
    <div class="contact-form__field">
      <label for="contact-email">{formLabels.emailLabel}</label>
      <input
        id="contact-email"
        type="email"
        name="email"
        required
        autocomplete="email"
        class="contact-form__input"
        aria-describedby={inputErrors.email ? "contact-email-error" : undefined}
        aria-invalid={!!inputErrors.email}
      />
      {inputErrors?.email && (
        <span id="contact-email-error" class="contact-form__field-error">
          {inputErrors.email.join(", ")}
        </span>
      )}
    </div>
    <div class="contact-form__field">
      <label for="contact-message">{formLabels.messageLabel}</label>
      <textarea
        id="contact-message"
        name="message"
        required
        rows={4}
        class="contact-form__input contact-form__textarea"
        aria-describedby={inputErrors.message ? "contact-message-error" : undefined}
        aria-invalid={!!inputErrors.message}
      />
      {inputErrors?.message && (
        <span id="contact-message-error" class="contact-form__field-error">
          {inputErrors.message.join(", ")}
        </span>
      )}
    </div>
    <button type="submit" class="contact-form__submit">
      {formLabels.submitLabel}
    </button>
  </form>
</div>

<style>
  .contact-form__success {
    padding: var(--space-md) var(--space-lg);
    margin-bottom: var(--space-lg);
    background: rgba(34, 197, 94, 0.12);
    border: 1px solid rgba(34, 197, 94, 0.35);
    border-radius: var(--radius-md);
    color: #86efac;
    font-size: 0.9375rem;
    line-height: 1.5;
  }

  .contact-form__error {
    padding: var(--space-md) var(--space-lg);
    margin-bottom: var(--space-lg);
    background: rgba(239, 68, 68, 0.12);
    border: 1px solid rgba(239, 68, 68, 0.35);
    border-radius: var(--radius-md);
    color: #fca5a5;
    font-size: 0.9375rem;
    line-height: 1.5;
  }

  .contact-form__form {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .contact-form__field {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .contact-form__field label {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    letter-spacing: 0.02em;
  }

  .contact-form__input {
    width: 100%;
    padding: var(--space-md) var(--space-lg);
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: var(--radius-md);
    color: var(--color-text-primary);
    font-family: inherit;
    font-size: 1rem;
    line-height: 1.5;
    transition:
      border-color var(--motion-duration-fast) var(--motion-ease-standard),
      background var(--motion-duration-fast) var(--motion-ease-standard),
      box-shadow var(--motion-duration-fast) var(--motion-ease-standard);
  }

  .contact-form__input::placeholder {
    color: var(--color-text-muted);
  }

  .contact-form__input:hover {
    border-color: rgba(255, 255, 255, 0.28);
    background: rgba(255, 255, 255, 0.05);
  }

  .contact-form__input:focus {
    border-color: rgba(127, 114, 255, 0.6);
    background: rgba(255, 255, 255, 0.05);
    box-shadow: 0 0 0 3px rgba(127, 114, 255, 0.15);
    outline: none;
  }

  .contact-form__input[aria-invalid="true"] {
    border-color: rgba(239, 68, 68, 0.6);
    box-shadow: 0 0 0 2px rgba(239, 68, 68, 0.15);
  }

  .contact-form__textarea {
    resize: vertical;
    min-height: 6.5rem;
    padding-top: var(--space-md);
  }

  .contact-form__field-error {
    font-size: 0.8125rem;
    color: #fca5a5;
    margin-top: var(--space-2xs);
  }

  .contact-form__submit {
    align-self: flex-start;
    margin-top: var(--space-xs);
    padding: var(--space-md) var(--space-2xl);
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: var(--radius-md);
    color: var(--color-text-primary);
    font-family: var(--font-family-display);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    transition:
      border-color var(--motion-duration-fast) var(--motion-ease-standard),
      color var(--motion-duration-fast) var(--motion-ease-standard),
      background var(--motion-duration-fast) var(--motion-ease-standard),
      transform var(--motion-duration-fast) var(--motion-ease-standard);
  }

  .contact-form__submit:hover {
    border-color: rgba(255, 255, 255, 0.5);
    background: rgba(255, 255, 255, 0.1);
    color: white;
    transform: translateY(-1px);
  }

  .contact-form__submit:focus-visible {
    outline: 2px solid rgba(127, 114, 255, 0.6);
    outline-offset: 2px;
  }

  .contact-form__submit:active {
    transform: translateY(0);
  }
</style>
