---
import "../../styles/global.css";
import { getTypedHomePageContent } from "../../content/home";
import { type Locale } from "../../lib/i18n";
import PageFrame from "../ui/PageFrame.astro";
import Homepage from "../../sections/Homepage.astro";
import SiteHeader from "../ui/SiteHeader.astro";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const homeContent = await getTypedHomePageContent(locale);
---

<PageFrame
  locale={locale}
  title={homeContent.seo.title}
  description={homeContent.seo.description}
>
  <SiteHeader
    locale={locale}
    navigation={homeContent.sections.section01.topNav}
    isHomepage={true}
  />
  <Homepage content={homeContent} locale={locale} />
</PageFrame>
